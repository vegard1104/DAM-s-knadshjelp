# Mal for miljøvariabler. Kopier til .env.local og fyll inn.
# .env.local er i .gitignore — den deles aldri.

# Supabase — Project URL og anon-key er offentlige (sikre med RLS)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase secret — kun server-side, aldri eksponert til klient
SUPABASE_SECRET_KEY=

# Anthropic API
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# App URL (localhost i dev, Vercel-URL i prod)
NEXT_PUBLIC_APP_URL=http://localhost:3000
